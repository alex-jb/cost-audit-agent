# Vercel — token at vercel.com/account/tokens (read-only is fine)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PLAN_USD=20         # your monthly base (Hobby=0, Pro=20, Enterprise=...)
VERCEL_BUILD_MINUTES_PRICE=0.12

# Anthropic — for full org-wide spend, get an admin key
# (scope: organization billing read). Without these, the agent falls back
# to scanning ~/.build-quality-agent/usage.jsonl + ~/.funnel-analytics-agent/usage.jsonl
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_ORG_ID=

# Bypass — set to 1 to make the agent a no-op
# COST_AUDIT_SKIP=0

# v0.3 — additional providers

# OpenPanel — plan-tier check (free / hobby / pro)
OPENPANEL_PLAN=free
# OPENPANEL_CLIENT_ID=                # optional, just liveness check

# HyperDX — plan-tier check (free / team / pro)
HYPERDX_PLAN=free
# HYPERDX_API_KEY=                    # optional

# Supabase — plan-tier + advisor enrichment
SUPABASE_PLAN=free                    # free / pro / team / enterprise
# Combined with the SUPABASE_PERSONAL_ACCESS_TOKEN + SUPABASE_PROJECT_REF
# already in v0.2's env block, the agent will also pull CRITICAL advisor
# count and surface them as cost-of-ownership signals.

# GitHub Actions — overage estimation for private repos
# (Public OSS repos have unlimited free minutes; this is for your private ones)
# GITHUB_TOKEN=                       # fine-grained PAT with read:actions
# GITHUB_REPO=alex-jb/your-private-repo
# GITHUB_PLAN=free                    # free (2000 min) / pro (3000) / team (3000) / enterprise (50000)
# GITHUB_AVG_MINUTES_PER_RUN=8        # tune to your workflow's typical duration
