# Vercel — token at vercel.com/account/tokens (read-only is fine)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PLAN_USD=20         # your monthly base (Hobby=0, Pro=20, Enterprise=...)
VERCEL_BUILD_MINUTES_PRICE=0.12

# Anthropic — for full org-wide spend, get an admin key
# (scope: organization billing read). Without these, the agent falls back
# to scanning ~/.build-quality-agent/usage.jsonl + ~/.funnel-analytics-agent/usage.jsonl
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_ORG_ID=

# Bypass — set to 1 to make the agent a no-op
# COST_AUDIT_SKIP=0
